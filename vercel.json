{
  "version": 2,
  "name": "coders-meet",
  "builds": [
    { 
      "src": "*.html", 
      "use": "@vercel/static" 
    },
    { 
      "src": "*.css", 
      "use": "@vercel/static" 
    },
    { 
      "src": "*.js", 
      "use": "@vercel/static" 
    }
  ],
  "routes": [
    {
      "src": "/styles.css",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/styles.css"
    },
    { 
      "src": "/(.*)", 
      "dest": "/$1" 
    }
  ]
} 